# Copy to .env and fill in your values

# Password to access the app
SCANNER_PASSWORD=changeme

# Profile names shown in the user picker (defaults: Ash, Misty)
PROFILE_1_NAME=Leo
PROFILE_2_NAME=Mara

# OVHcloud AI Endpoints key — enables vision LLM fallback when Tesseract fails
# Get from: OVHcloud Control Panel → AI & ML → AI Endpoints → Tokens
# Leave empty to use Tesseract only
OVH_API_KEY=
